# Shared access token used by translation and order-preparation pages.
TRANSLATION_ACCESS_TOKEN=

# Used by api/translate-description.js and optional DeepSeek mode in api/prepare-orders.js.
DEEPSEEK_API_KEY=

# Used by api/prepare-orders.js when OpenRouter is selected.
OPENROUTER_API_KEY=

# Used by api/fragrancex-costs.js to price supplier order costs server-side.
FRAGRANCEX_API_ID=
FRAGRANCEX_API_KEY=

# Upstash Redis REST env vars from Vercel Marketplace, used for daily FragranceX cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional conversion rate for FragranceX USD costs into Salla SAR order values.
USD_TO_SAR_RATE=3.75

# Optional public site URL sent to OpenRouter as HTTP-Referer.
SITE_URL=
